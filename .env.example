# Xiaobai Agent Configuration
# Copy this file to .env and fill in your values

# Default provider and model
XIAOBAI_PROVIDER=anthropic
XIAOBAI_MODEL=claude-sonnet-4-6
XIAOBAI_API_KEY=

# Provider API keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
ZHIPU_API_KEY=
MOONSHOT_API_KEY=
YI_API_KEY=
BAIDU_API_KEY=
MINIMAX_API_KEY=
BAICHU_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
XAI_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=

# Logging
XIAOBAI_LOG_LEVEL=info
XIAOBAI_LOG_FORMAT=pretty
