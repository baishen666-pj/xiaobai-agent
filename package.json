{
  "name": "xiaobai-agent",
  "version": "0.1.0",
  "description": "Fusion AI agent — multi-agent orchestration, 18+ LLM providers, streaming CLI, MCP integration, real-time dashboard, skill system, plugin marketplace",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "xiaobai": "dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./tools": {
      "import": "./dist/tools/registry.js",
      "types": "./dist/tools/registry.d.ts"
    },
    "./provider": {
      "import": "./dist/provider/router.js",
      "types": "./dist/provider/router.d.ts"
    }
  },
  "files": [
    "dist/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:dashboard": "vite build",
    "build:all": "npm run build:dashboard && npm run build",
    "dev": "tsx src/cli/index.ts",
    "dev:dashboard": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:api": "vitest run tests/e2e/real-api.test.ts",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:dashboard && npm run typecheck && npm test",
    "prepack": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "anthropic",
    "openai",
    "deepseek",
    "qwen",
    "mcp",
    "cli",
    "multi-agent",
    "orchestration",
    "coding-assistant",
    "streaming",
    "dashboard"
  ],
  "author": "baishen666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baishen666/xiaobai-agent"
  },
  "homepage": "https://github.com/baishen666/xiaobai-agent#readme",
  "bugs": {
    "url": "https://github.com/baishen666/xiaobai-agent/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "highlight.js": "^11.11.1",
    "ink": "^5.2.0",
    "openai": "^4.98.0",
    "react": ">=18.0.0",
    "string-width": "^8.2.1",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.2",
    "react-dom": "^19.2.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^8.0.13",
    "vitest": "^3.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
